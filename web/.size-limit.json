[
  {
    "name": "initial JS (gz) — Preact + signals + Overview + Nav + AppShell + Login (Phase 5e)",
    "path": "../internal/dashboard/spa/dist/assets/index-*.js",
    "limit": "16 KB",
    "gzip": true
  },
  {
    "name": "uPlot chart chunk (gz) — loads on first chart mount only",
    "path": "../internal/dashboard/spa/dist/assets/Chart-*.js",
    "limit": "25 KB",
    "gzip": true
  },
  {
    "name": "lazy panel chunks (gz) — Sources/Pages/SEO/Campaigns/Realtime/Admin + TrendChart/DualBar",
    "path": "../internal/dashboard/spa/dist/assets/{Sources,Pages,SEO,Campaigns,Realtime,Admin,TrendChart,DualBar,LazyChart}-*.js",
    "limit": "10 KB",
    "gzip": true
  },
  {
    "name": "statnive-spa.css (gz) — tokens + reset + AppShell + components + @font-face rules (Phase 5e, fonts are separate WOFF2 assets)",
    "path": "../internal/dashboard/spa/dist/assets/index-*.css",
    "limit": "5 KB",
    "gzip": true
  },
  {
    "name": "per-panel CSS chunks (gz) — Admin + panels + Chart",
    "path": "../internal/dashboard/spa/dist/assets/{Admin,panels,Chart}-*.css",
    "limit": "3 KB",
    "gzip": true
  }
]
