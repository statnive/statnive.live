{
  "name": "statnive-spa",
  "version": "0.1.0",
  "description": "statnive-live dashboard SPA — Preact + signals + TypeScript, embedded into the Go binary via go:embed.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest run --environment=jsdom",
    "lint": "eslint src --ext .js,.mjs --no-error-on-unmatched-pattern && tsc --noEmit",
    "bundle-gate": "size-limit"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@preact/signals": "^1.3.0",
    "@size-limit/file": "^11.1.6",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^25.6.0",
    "eslint": "^8.57.0",
    "jsdom": "^25.0.1",
    "preact": "^10.25.0",
    "size-limit": "^11.1.6",
    "typescript": "^5.7.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
