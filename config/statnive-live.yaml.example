# statnive-live — production configuration template.
#
# Ships in the air-gap bundle as `statnive-live.yaml.example`; the
# install script copies it to `/etc/statnive-live/config.yaml` on first
# run (and NEVER overwrites an existing config). Edit in place.
#
# Every key here mirrors one in the Go binary's loadConfig. The CI test
# `cmd/statnive-live/config_test.go` round-trips this file and fails the
# build if the example drifts from the binary's schema.
#
# Every key has a matching STATNIVE_<KEY> env var. Env wins over YAML;
# in production the systemd unit drop-in at
# /etc/systemd/system/statnive-live.service.d/env.conf is the canonical
# config surface for paths and secrets.

# ─── Deployment posture (informational label) ──────────────────────────
# The binary does NOT branch on this — every behavioural knob below
# (license, consent, outbound, NTP, TLS) is independently configured.
# This label exists so /healthz + audit can report the operator's
# declared posture, making "wrong posture / wrong knobs" drift visible.
#
# Three canonical postures, each with its own knob recipe below:
#
#   "saas"            — we host on statnive.live / Netcup; multi-tenant
#                       across customer site_ids. license.file=""
#                       (no per-binary license); consent.required=true
#                       (GDPR for EU visitors); outbound opt-in for
#                       Telegram + Polar.sh.
#
#   "outside-iran"    — customer hosts on their own VPS (Hetzner/AWS/
#                       bare metal). Single-customer, license required.
#                       license.file=/etc/statnive-live/license.jwt;
#                       consent.required=true (default; flip if customer
#                       has no EU visitors); outbound opt-in (customer
#                       choice — ACME, Telegram, etc.).
#
#   "inside-iran"     — customer hosts on Asiatech inside Iran.
#                       Air-gap-capable. license.file=/etc/...; consent
#                       .required=false (CLAUDE.md Privacy Rule 5
#                       carve-out — Iran has no GDPR); outbound DROP
#                       via --apply-iptables; NTP via chrony.conf
#                       .asiatech; TLS via outside-Iran cert-forge.
#
# Empty = unset (legacy / dev). Allowed values: saas, outside-iran,
# inside-iran. Anything else fails fast at boot.
posture: ""   # STATNIVE_POSTURE

# ─── Master secret ─────────────────────────────────────────────────────
# The master secret value NEVER lives in YAML. Set STATNIVE_MASTER_SECRET
# (64 hex chars or ≥32 raw bytes) via systemd EnvironmentFile, OR drop a
# chmod-0600 file at master_secret_path.
master_secret_path: "/etc/statnive-live/master.key"   # STATNIVE_MASTER_SECRET_PATH

# ─── HTTP server ───────────────────────────────────────────────────────
server:
  listen:        "0.0.0.0:8080"   # STATNIVE_SERVER_LISTEN
  read_timeout:  "5s"             # STATNIVE_SERVER_READ_TIMEOUT
  write_timeout: "5s"             # STATNIVE_SERVER_WRITE_TIMEOUT

# ─── TLS (top-level; not nested under server) ──────────────────────────
# Leave empty to run plain HTTP (only safe behind a TLS-terminating
# reverse proxy). Rotate manually; the cert-expiry watcher emits alerts
# at <30 d and <7 d. Autocert + LE slips to v1.1.
tls:
  cert_file: "/etc/statnive-live/tls/fullchain.pem"   # STATNIVE_TLS_CERT_FILE
  key_file:  "/etc/statnive-live/tls/privkey.pem"     # STATNIVE_TLS_KEY_FILE

# ─── ClickHouse ────────────────────────────────────────────────────────
# Bound to 127.0.0.1 by Security Rule 2. The binary connects over the
# local network stack; no TLS on the CH hop. cluster="" = single-node.
clickhouse:
  addr:     "127.0.0.1:9000"   # STATNIVE_CLICKHOUSE_ADDR
  database: "statnive"          # STATNIVE_CLICKHOUSE_DATABASE
  username: "default"           # STATNIVE_CLICKHOUSE_USERNAME
  password: ""                  # STATNIVE_CLICKHOUSE_PASSWORD
  cluster:  ""                  # STATNIVE_CLICKHOUSE_CLUSTER

# ─── Ingest (WAL + batching) ───────────────────────────────────────────
# CLAUDE.md Architecture Rule 4: WAL for durability, batch 500ms / 1000 rows.
ingest:
  wal_dir:                              "/var/lib/statnive-live/wal"  # STATNIVE_INGEST_WAL_DIR
  wal_max_bytes:                        10737418240                   # STATNIVE_INGEST_WAL_MAX_BYTES (10 GiB)
  batch_rows:                           1000                          # STATNIVE_INGEST_BATCH_ROWS
  batch_interval:                       "500ms"                       # STATNIVE_INGEST_BATCH_INTERVAL
  batch_max_bytes:                      10485760                      # STATNIVE_INGEST_BATCH_MAX_BYTES (10 MiB)
  max_pageviews_per_minute_per_visitor: 500                           # STATNIVE_INGEST_MAX_PAGEVIEWS_PER_MINUTE_PER_VISITOR

# ─── Enrichment ────────────────────────────────────────────────────────
# sources_path = YAML of Iranian-referrer / channel-grouping rules.
# geoip_bin_path = IP2Location LITE DB23, monthly refresh; SIGHUP hot-reloads.
# Empty geoip_bin_path = enrichment becomes no-op; country_code defaults to "--".
enrich:
  sources_path:   "/etc/statnive-live/sources.yaml"                          # STATNIVE_ENRICH_SOURCES_PATH
  geoip_bin_path: "/etc/statnive-live/geoip/IP2LOCATION-LITE-DB23.BIN"       # STATNIVE_ENRICH_GEOIP_BIN_PATH

# ─── Audit ─────────────────────────────────────────────────────────────
audit:
  path: "/var/log/statnive-live/audit.jsonl"   # STATNIVE_AUDIT_PATH

# ─── Alerts (file sink) ────────────────────────────────────────────────
# Phase 8 file-sink only; remote sinks (Telegram, syslog) land in v1.1.
alerts:
  sink_path: "/var/log/statnive-live/alerts.jsonl"   # STATNIVE_ALERTS_SINK_PATH
  host_tag:  ""                                       # STATNIVE_ALERTS_HOST_TAG

# ─── Rate limiting ─────────────────────────────────────────────────────
ratelimit:
  requests_per_minute: 6000   # STATNIVE_RATELIMIT_REQUESTS_PER_MINUTE

# ─── Dashboard ─────────────────────────────────────────────────────────
# spa_enabled gates the embedded Preact SPA at /app/*. Phase 2b ships
# session + RBAC, so production may flip to true.
# bearer_token is the legacy Phase 3b pre-shared secret kept for
# back-compat with the Phase 5a-smoke harness; new auth uses sessions.
dashboard:
  bearer_token: ""        # STATNIVE_DASHBOARD_BEARER_TOKEN
  spa_enabled:  true      # STATNIVE_DASHBOARD_SPA_ENABLED
  # geo_enabled gates /api/stats/geo (v1.1-geo). Migration 019 creates
  # the daily_geo table + MV at boot regardless of this flag — the MV
  # starts catching new events immediately. Flip this to true ONLY
  # after running `make geo-backfill FROM=<earliest> TO=<today>` so
  # historical data is loaded, then SIGHUP. When false the endpoint
  # returns 501 and the SPA's Geo panel renders a "coming soon" state.
  geo_enabled:  false     # STATNIVE_DASHBOARD_GEO_ENABLED

# ─── MCP read-only agent surface (statnive-live mcp serve) ─────────────
# Consumed ONLY by the `mcp` subcommand; the daemon ignores it. stdio
# needs no config. The HTTP transport is opt-in, loopback-by-default, and
# fail-closed: a non-loopback bind is refused unless posture=saas AND TLS
# is configured. Per-actor budgets cap query volume (anti-exfiltration);
# the wildcard actor (legacy bearer / --all-sites) gets every cap × the
# tier factor.
mcp:
  http:
    enabled:               false           # STATNIVE_MCP_HTTP_ENABLED
    profile:               "loopback"      # loopback | chatgpt-app (v2.5)
    listen:                "127.0.0.1:8081" # STATNIVE_MCP_HTTP_LISTEN
    rate_limit_per_minute: 120
    tls_cert_file:         ""
    tls_key_file:          ""
  budget:
    calls_per_min:           60
    rows_per_min:            20000
    calls_per_session:       2000
    rows_per_session:        500000
    distinct_sites_per_min:  5
    wildcard_tier_factor:    0.25
  widgets:
    enabled: false                          # v3 ChatGPT-app widgets (schema-only in v2)

# ─── Auth (Phase 2b: sessions, RBAC, lockout) ──────────────────────────
# First-run bootstrap reads STATNIVE_BOOTSTRAP_ADMIN_{EMAIL,PASSWORD,USERNAME}
# and creates the initial admin user + site. After first boot the envs
# can be cleared (the bootstrap is idempotent: it skips when any admin
# exists).
auth:
  session:
    ttl:         "336h"              # STATNIVE_AUTH_SESSION_TTL (14 d)
    cookie_name: "statnive_session"  # STATNIVE_AUTH_SESSION_COOKIE_NAME
    secure:      true                # STATNIVE_AUTH_SESSION_SECURE (HTTPS only)
    same_site:   "lax"               # STATNIVE_AUTH_SESSION_SAME_SITE
    cache_ttl:   "60s"               # STATNIVE_AUTH_SESSION_CACHE_TTL
  bcrypt_cost: 12                    # STATNIVE_AUTH_BCRYPT_COST
  login_rate_limit:
    requests: 10                     # STATNIVE_AUTH_LOGIN_RATE_LIMIT_REQUESTS
    window:   "1m"                   # STATNIVE_AUTH_LOGIN_RATE_LIMIT_WINDOW
  lockout:
    fails:   10                      # STATNIVE_AUTH_LOCKOUT_FAILS
    decay:   "15m"                   # STATNIVE_AUTH_LOCKOUT_DECAY
    lockout: "5m"                    # STATNIVE_AUTH_LOCKOUT_LOCKOUT
  bootstrap:
    site_id:  1                      # STATNIVE_AUTH_BOOTSTRAP_SITE_ID
    username: "admin"                # STATNIVE_AUTH_BOOTSTRAP_USERNAME
  default_site_id: 1                 # STATNIVE_AUTH_DEFAULT_SITE_ID
  demo_banner:    ""                 # STATNIVE_AUTH_DEMO_BANNER

# ─── Consent posture (CLAUDE.md Privacy Rules 5 + 9) ───────────────────
# required:   if true (SaaS), the _statnive cookie + user_id hash are
#             only set when the request carries `X-Statnive-Consent: given`
#             (set by the customer's CMP integration). Events still
#             ingest anonymously when missing — only visitor identity
#             is suppressed. Flip to false on self-hosted Iran tiers
#             (no GDPR; CLAUDE.md Privacy Rule 5).
#
# Note: respect_gpc and respect_dnt are now per-site columns in
# statnive.sites (migration 006). Toggle them via the admin UI at
# /admin/sites or via PATCH /api/admin/sites/{id} with respect_dnt /
# respect_gpc / track_bots in the body. The global cfg flags have
# been removed.
consent:
  required:    true    # STATNIVE_CONSENT_REQUIRED
  # Segments-feature flags (Phase 1). See appConfig.Consent docstring in
  # cmd/statnive-live/main.go for the full rationale.
  require_for_segments: true    # STATNIVE_CONSENT_REQUIRE_FOR_SEGMENTS
  queue_until_resolved: false   # STATNIVE_CONSENT_QUEUE_UNTIL_RESOLVED
  # api_tokens: list of {token_hash_hex, site_id, label, role}; populate
  # via `statnive-live admin token issue ...` rather than editing here.
  # api_tokens:
  #   - token_hash_hex: "<sha256 hex>"
  #     site_id: 1
  #     label: "ci-smoke"
  #     role: "viewer"

# ─── Admin (operator-side identity) ────────────────────────────────────
# operator_email is the SaaS operator account that migration 010 grants
# admin-on-all-sites to on first apply (idempotent on rerun). Empty
# disables the bootstrap entirely (dev / fresh deploy / CI). When set,
# must look like an email — config loader rejects values that don't match
# the basic email regex (so the migration template's string substitution
# can't be exploited by a crafted YAML value).
admin:
  operator_email: ""   # STATNIVE_ADMIN_OPERATOR_EMAIL

# ─── Feature flags ─────────────────────────────────────────────────────
# per_site_admin gates the v0.0.9+ per-site admin authorization path
# (RequireSiteRole middleware reading ?site_id=N against the user_sites
# grant table). Default off in v0.0.9 — production behaves byte-identical
# to v0.0.8 on deploy. Flipped to true in v0.0.10 once the handler
# refactor + frontend redesign land.
features:
  per_site_admin: false   # STATNIVE_FEATURES_PER_SITE_ADMIN — on: RequireSiteRole middleware; off: legacy single-site RequireRole (v0.0.9 default; flip to true after smoke verifies on prod)

# ─── License verification (opt-in, offline Ed25519) ────────────────────
# Empty `file` is the default and disables verification — boot proceeds
# as it always has. Existing deploys (statnive.com / .de / fr.statnive.com)
# leave this section unset; the binary is byte-for-byte compatible with
# their pre-WP1 configs.
#
# Phase 10 / Iranian-DC operators uncomment and set `file` to the path of
# the JWT-EdDSA license token shipped by the upstream signer. The public
# key is baked into the binary; tampering with the file gets you an
# `ErrInvalidSignature` at startup.
#
# `phone_home` MUST remain false for any Iranian-DC deployment per the
# `iran-license-verify-must-be-offline` rule (CLAUDE.md anti-patterns).
# Kept in the schema so air-gap-validator can audit accidental flips.
#
# license:
#   file:       "/etc/statnive-live/license.jwt"   # STATNIVE_LICENSE_FILE
#   phone_home: false                              # STATNIVE_LICENSE_PHONE_HOME

# ─── Opt-in outbound features (ALL default OFF) ────────────────────────
# Turning any on breaks the Isolation invariant (zero required outbound).
# Placeholders shown for visibility; activated in v1.1 / Phase 11.
#
# outbound:
#   allowlist: []          # FQDNs permitted for http.Client dial
# billing:
#   polar:
#     enabled: false
# email:
#   enabled: false
