{
  "title": "Statnive Load Gate — Phase 10",
  "uid": "statnive-load-gate",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "tags": ["load-gate", "phase-7e"],
  "templating": {
    "list": [
      {
        "name": "test_run_id",
        "type": "textbox",
        "label": "test_run_id",
        "current": {"value": "", "text": ""}
      },
      {
        "name": "phase",
        "type": "custom",
        "label": "Phase",
        "options": [
          {"text": "P1", "value": "P1", "selected": true},
          {"text": "P2", "value": "P2"},
          {"text": "P3", "value": "P3"},
          {"text": "P4", "value": "P4"},
          {"text": "P5", "value": "P5"}
        ]
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Chaos scenarios",
        "datasource": "Prometheus",
        "enable": true,
        "expr": "ALERTS{alertname=~\".*Chaos.*\"}",
        "iconColor": "red"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Oracle — server-side event loss (per (run, node))",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "max by (generator_node_id) (statnive_load_gate_loss_fraction{test_run_id=\"$test_run_id\"})"
        }
      ],
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Oracle — duplicate count",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(statnive_load_gate_duplicates_total{test_run_id=\"$test_run_id\"})"
        }
      ],
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Oracle — latency (send_ts → time)",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(statnive_load_gate_latency_seconds_bucket{test_run_id=\"$test_run_id\"}[1m])))",
          "legendFormat": "p99"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(statnive_load_gate_latency_seconds_bucket{test_run_id=\"$test_run_id\"}[1m])))",
          "legendFormat": "p95"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "WAL fsync p99",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(statnive_wal_fsync_duration_seconds_bucket[1m])))"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "ClickHouse active parts",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "clickhouse_async_metrics_active_parts"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "PII leaks (must be 0)",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(statnive_pii_leak_total[$__range])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 16}
    }
  ]
}
