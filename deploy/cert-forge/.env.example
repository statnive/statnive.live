# cert-forge env file. Copy to /etc/cert-forge/.env, fill in, chmod 0600.
# The docker-compose stack + host-systemd unit both source this.

# --- ACME / Let's Encrypt -----------------------------------------------------
ACME_EMAIL="ops@example.com"
# Set to "https://acme-staging-v02.api.letsencrypt.org/directory" for dry-runs.
# Empty / unset = production LE.
ACME_SERVER=""

# --- Domain(s) to issue ------------------------------------------------------
# Space-separated list. Each must be reachable by the Pars.ir API.
ACME_DOMAINS="customer-1.statnive.ir customer-2.statnive.ir"

# --- Pars.ir DNS-01 provider --------------------------------------------------
# Set both. The dns_parsir.sh provider reads from the process environment.
PARSIR_API_KEY=""
PARSIR_API_ENDPOINT="https://api.pars.ir/v1/dns"

# --- Asiatech rsync target ---------------------------------------------------
# [user@]host[:port] — must accept the SSH key at /etc/cert-forge/ssh/id_ed25519.
# The target directory on the production box is always /etc/statnive-live/tls/.
ASIATECH_HOST="root@customer-asiatech.example.com"

# Comma-separated mapping of <issued-domain>:<remote-host>. Use when the bastion
# manages certs for several Asiatech boxes — each cert pushes only to the
# matching host. Empty = every cert pushes to $ASIATECH_HOST.
ASIATECH_DOMAIN_TO_HOST=""

# --- Operational tunables ----------------------------------------------------
# Days-before-expiry to start renewing. acme.sh default is 60 (issue every
# 30 days). Lower for tighter pin / higher for less-frequent rotation.
ACME_RENEW_DAYS="30"
