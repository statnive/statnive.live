# deploy/iptables/rules.v4 — statnive-live host firewall (IPv4)
#
# Apply: iptables-restore < deploy/iptables/rules.v4
# Persist on Debian/Ubuntu: netfilter-persistent save
# nftables hosts: iptables-restore-translate -f deploy/iptables/rules.v4 > statnive.nft
#
# Default posture: drop INPUT + FORWARD, allow OUTPUT (outbound restricted
# at the app layer by internal/httpclient/guarded.go — see CLAUDE.md
# Security #14). Internal binds (127.0.0.1:8080 app, 127.0.0.1:9000 CH)
# are covered by the loopback accept below; no explicit rule needed.
*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]
-A INPUT -i lo -j ACCEPT
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -p tcp --dport 22 -j ACCEPT
-A INPUT -p tcp --dport 80 -j ACCEPT
-A INPUT -p tcp --dport 443 -j ACCEPT
-A INPUT -p icmp --icmp-type echo-request -m limit --limit 1/s --limit-burst 3 -j ACCEPT
COMMIT
