# Build artifacts. Anchor to repo root — leading slash prevents the
# pattern from also matching cmd/statnive-live/ (the package dir for
# the entry point's main.go).
bin/
*.exe
/statnive-live
# `make airgap-bundle` output — tarball + extracted dir + SHA256SUMS
# + signature. Reproducible release artifacts; never source.
/build/

# Frontend
web/dist/
web/node_modules/
tracker/dist/
tracker/node_modules/

# SPA embed target — vite.config.ts writes hashed bundles here, and
# internal/dashboard/spa/dashboard.go embeds them via //go:embed. Must
# be rebuilt fresh on every checkout (make build depends on make web-build).
internal/dashboard/spa/dist/

# Runtime data (not source)
wal/
data/
tmp/
*.log
audit.jsonl

# Environment + secrets (NEVER commit master.key)
.env
.env.local
config/master.key

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Coverage / profiling
coverage.out
coverage.html
*.prof

# vendor/ is INTENTIONALLY tracked (offline build invariant — PLAN.md verification 18)
releases/load-gate/*-k6.log
